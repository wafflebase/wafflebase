{
  "frontend": {
    "chunkBudgets": {
      "maxChunkKb": 710,
      "maxChunkCount": 70,
      "overrides": [
        {
          "pattern": "^pending-imports-",
          "maxKb": 1500,
          "reason": "PDF export bundle (pdf-lib + fontkit), loaded only when user clicks Export PDF"
        }
      ]
    }
  },
  "entropy": {
    "deadCode": {
      "enabled": true
    },
    "docStaleness": {
      "enabled": true,
      "designDir": "docs/design"
    },
    "dependencyFreshness": {
      "enabled": true,
      "failOnCritical": true
    }
  }
}
