{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@wafflebase/sheets$": "<rootDir>/../sheets/src/index.ts",
    "^@wafflebase/docs$": "<rootDir>/../docs/src/node.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "maxWorkers": 1
}
