{
  "name": "@wafflebase/cli",
  "version": "0.5.1",
  "description": "CLI for Wafflebase spreadsheet API",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "wafflebase": "./dist/bin.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint:check": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "commander": "^13.0.0",
    "fontkit": "^2.0.4",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/fontkit": "^2.0.0",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "4.1.8",
    "@wafflebase/docs": "workspace:*",
    "@wafflebase/slides": "workspace:*",
    "eslint": "^9.18.0",
    "jszip": "^3.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
