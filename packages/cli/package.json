{
  "name": "@wafflebase/cli",
  "version": "0.3.4",
  "description": "CLI for Wafflebase spreadsheet API",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "wafflebase": "./dist/bin.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint:check": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "open": "^11.0.0",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "3.1.1",
    "eslint": "^9.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.0"
  }
}
