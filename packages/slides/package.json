{
  "name": "@wafflebase/slides",
  "private": true,
  "version": "0.4.0",
  "license": "Apache-2.0",
  "description": "Presentation engine for Wafflebase",
  "type": "module",
  "main": "dist/wafflebase-slides.cjs",
  "module": "dist/wafflebase-slides.es.js",
  "types": "dist/wafflebase-slides.es.d.ts",
  "exports": {
    ".": {
      "types": "./dist/wafflebase-slides.es.d.ts",
      "import": "./dist/wafflebase-slides.es.js",
      "require": "./dist/wafflebase-slides.cjs",
      "default": "./dist/wafflebase-slides.es.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --watch --passWithNoTests",
    "build": "vite --config vite.build.ts build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@wafflebase/docs": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.3.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.1.1"
  }
}
